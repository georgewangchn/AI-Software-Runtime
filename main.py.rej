+def fib(n):
+    cache = {}
+    def helper(n):
+        if n <= 1:
+            return n
+        if n in cache:
+            return cache[n]
+        result = helper(n-1) + helper(n-2)
+        cache[n] = result
+        return result
+    return helper(n)

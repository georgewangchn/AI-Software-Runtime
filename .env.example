# ASR Environment Configuration
# Copy this file to .env and fill in your LLM endpoint details.
#
# NOTE: ASR delegates all LLM calls to the `opencode` CLI.
# These variables are read by create_default_config() for reference,
# but the actual LLM provider is configured in .opencode/config.json
# (or ~/.config/opencode/opencode.json globally).
#
# Run `asr init --project .` to generate an opencode config template.

FEASIBILITY_LLM_API_BASE=http://127.0.0.1:8000/v1
FEASIBILITY_LLM_API_KEY=empty
FEASIBILITY_LLM_MODEL=glm-4.7-fp8
FEASIBILITY_LLM_CONTEXT=262144

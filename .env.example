# ASR 环境变量配置
# 复制此文件为 .env 并填入你的实际值
# cp .env.example .env

# ============================================================
# LLM 模型配置（必填）
# ============================================================

# OpenAI 兼容接口地址（支持 vLLM / Ollama / 任意兼容服务）
FEASIBILITY_LLM_API_BASE=http://localhost:8000/v1

# API 密钥（本地部署可填 empty，OpenAI 官方填真实 key）
FEASIBILITY_LLM_API_KEY=your-api-key-here

# 模型名称（示例）
# 本地 vLLM:  glm-4.7-fp8 / qwen3-80b / deepseek-v3
# OpenAI:     gpt-4o / gpt-4-turbo
# Anthropic:  anthropic/claude-3-5-sonnet  (需 litellm 前缀)
FEASIBILITY_LLM_MODEL=your-model-name

# 上下文窗口大小（token 数，按模型实际能力填写）
FEASIBILITY_LLM_CONTEXT=131072

# ============================================================
# ASR 运行参数（可选，有默认值）
# ============================================================

# opencode 调用超时（秒），默认 24400
# ASR_OPENCODE_TIMEOUT=24400

# 设为 1 启用详细日志
# ASR_VERBOSE=1
